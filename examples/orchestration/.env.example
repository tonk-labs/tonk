# Orchestrator Configuration
AI_WORKER_URL=http://localhost:5556
MAX_TURNS=20
VERBOSE=false

# Claude Code API Key (required)
ANTHROPIC_API_KEY=your_api_key_here

# Browser MCP Configuration (optional overrides)
BROWSER_MCP_COMMAND=npx
BROWSER_MCP_ARGS=-y @anthropic-ai/mcp-server-browser
# BROWSER_MCP_ENV={"SOME_VAR": "value"}

# Gmail MCP Configuration
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
GMAIL_REDIRECT_URI=http://localhost:8080/oauth2callback
GMAIL_REFRESH_TOKEN=your_refresh_token

# Gmail MCP Command Configuration (optional overrides)
GMAIL_MCP_COMMAND=npx
GMAIL_MCP_ARGS=-y gmail-mcp-server
# GMAIL_MCP_ENV={"ADDITIONAL_VAR": "value"}

# AI Worker Configuration (for the worker itself)
WORKER_PORT=5556
SYNC_WS_URL=ws://localhost:7777/sync
SYNC_URL=http://localhost:7777